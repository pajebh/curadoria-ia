# ─── Backend ──────────────────────────────────────────────────────────────────

# PostgreSQL (Neon)
DATABASE_URL=postgresql+asyncpg://user:password@host/curadoria

# Redis (Upstash) — formato rediss:// para TLS
REDIS_URL=rediss://default:password@host:6379

# JWT — gere com: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-generate-a-strong-secret
JWT_ALGORITHM=HS256
JWT_TTL_DAYS=180

# IA primária — Groq
GROQ_API_KEY=gsk_...

# IA fallback — Google Gemini
GEMINI_API_KEY=AIza...

# Ambiente
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=INFO

# Sentry (opcional em dev)
SENTRY_DSN=

# Better Stack / Logtail (opcional em dev)
LOGTAIL_TOKEN=

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
# (próximos de .env.local no Next.js — não commitados)

# URL interna do backend (SSR)
API_URL=http://localhost:8000

# URL pública do backend (client-side SSE)
NEXT_PUBLIC_API_URL=http://localhost:8000
